{
  "description": "Git remote pulse-check on session start (read-only).",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/git-pulse.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
