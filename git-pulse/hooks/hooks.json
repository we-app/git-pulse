{
  "description": "Git remote pulse-check on session start (heartbeat) + first user prompt of each session (prominent chat surface). Read-only.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/git-pulse.py\" session-start",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/git-pulse.py\" user-prompt-submit",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
